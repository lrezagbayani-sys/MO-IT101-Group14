    public static void displayStaffView(String id) {
        try (BufferedReader br = new BufferedReader(new FileReader(CSV_FILE))) {
            String line;
            br.readLine();
            while ((line = br.readLine()) != null) {
                String[] data = line.split(",(?=(?:[^\"]*\"[^\"]*\")*[^\"]*$)");
                if (data[1].trim().equals(id.trim())) {
                    System.out.println("\n--- Employee Records ---");
                    System.out.println("1. Employee #: " + data[1]);
                    System.out.println("2. Employee Name: " + data[2]);
                    System.out.println("3. Birthday: " + data[3]);

                    double rate       = Double.parseDouble(data[16].replace("\"", "").replace(",", ""));
                    double totalHours = Double.parseDouble(data[15].replace("\"", "").replace(",", ""));
                    double halfHours  = totalHours / 2;
                    double grossHalf  = rate * halfHours;

                    double sss      = Double.parseDouble(data[7].replace("\"", "").replace(",", ""));
                    double phil     = Double.parseDouble(data[8].replace("\"", "").replace(",", ""));
                    double pagibig  = Double.parseDouble(data[9].replace("\"", "").replace(",", ""));
                    double tax      = Double.parseDouble(data[10].replace("\"", "").replace(",", ""));
                    double totalDed = sss + phil + pagibig + tax;

                    System.out.println("4. Cutoff Date: June 1 to June 15");
                    System.out.println("5. Total Hours Worked: " + String.format("%.2f", halfHours));
                    System.out.println("6. Gross Salary: PHP " + String.format("%.2f", grossHalf));
                    System.out.println("7. Net Salary: PHP " + String.format("%.2f", grossHalf));
                    System.out.println("8. Cutoff Date: June 16 to June 30");
                    System.out.println("9. Total Hours Worked: " + String.format("%.2f", halfHours));
                    System.out.println("10. Gross Salary: PHP " + String.format("%.2f", grossHalf));
                    System.out.println("11. Each Deduction:");
                    System.out.println("12.   SSS: PHP "        + data[7].replace("\"", ""));
                    System.out.println("13.   PhilHealth: PHP " + data[8].replace("\"", ""));
                    System.out.println("14.   Pag-IBIG: PHP "   + data[9].replace("\"", ""));
                    System.out.println("15.   Tax: PHP "        + data[10].replace("\"", ""));
                    System.out.println("16. Total Deductions: PHP " + String.format("%.2f", totalDed));
                    System.out.println("17. Net Salary: PHP " + String.format("%.2f", (grossHalf - totalDed)));

                    System.out.println("\nComputation Successful. Thank you for using the MotorPH Payroll System!");
                    System.out.println("Program Terminated.");
                    return;
                }
            }
            System.out.println("\nAccess Denied: Employee # does not exist.");
            System.out.println("Program Terminated.");
        } catch (Exception e) {
            System.out.println("Error: " + e.getMessage());
        }
    }

