import java.io.BufferedReader; // Used to read text from a character-input stream
import java.io.FileReader; // Used to read data from files
import java.util.Scanner; // Used to capture user input from the console

public class MO_IT101_Group14 { // Main class defined as requested

    // CSV path constants for NetBeans and cross-platform compatibility
    private static final String ATTENDANCE_CSV = "src/Employee Attendance Record.csv";
    private static final String DATABASE_CSV = "src/Employee Database.csv";
    private static final String SSS_CSV = "src/SSS Deduction.csv";

    // Constant for navigation option 1
    public static final int OPTION_ONE = 1;
    // Constant for navigation option 2
    public static final int OPTION_TWO = 2;
    // Constant for navigation option 3
    public static final int OPTION_THREE = 3;
    // Constant representing the maximum valid month option in the menu
    public static final int OPTION_MAX_MONTH = 8;

    // Main entry point of the Java application
    public static void main(String[] args) {
        // Create scanner instance to read console input
        Scanner inputScanner = new Scanner(System.in);

        // Prompt the user for the system username
        System.out.print("Username: ");
        // Capture the username string and trim whitespace
        String usernameInput = inputScanner.nextLine().trim();

        // Prompt the user for the system password
        System.out.print("Password: ");
        // Capture the password string and trim whitespace
        String passwordInput = inputScanner.nextLine().trim();

        // Perform strict credential validation
        if (passwordInput.equals("12345") && (usernameInput.equals("employee") || usernameInput.equals("payroll_staff"))) {
            // Routing logic based on username identity
            if (usernameInput.equals("employee")) {
                // Welcome message specifically for general employees
                System.out.println("Login Successful! \n\n--- Welcome, MotorPH Employee! ---");

                // Invoke the procedural method for the Employee Portal
                processEmployeePortal(inputScanner);
            } else {
                // Welcome message specifically for administrative payroll staff
                System.out.println("Login Successful! \n\n--- Welcome, MotorPH Payroll Staff! ---");

                // Invoke the procedural method for the Payroll Staff Portal
                processStaffPortal(inputScanner);
            }
        } else {
            // Display denial message if credentials do not match
            System.out.println("\nAccess Denied: Invalid login credentials. Please try again.");

            // Display final termination message for security
            System.out.println("\nPROGRAM TERMINATED.");

            // Terminate the JVM process
            System.exit(0);
        }
    }

    // Procedural method designed for the Employee Portal interface
    public static void processEmployeePortal(Scanner scanner) {
        // Display functional options for the employee
        System.out.println("[1] Enter your employee number");

        // Option to safely exit the system
        System.out.println("[2] Exit the program");

        // Prompt for user selection
        System.out.print("Select option: ");

        // Capture the menu choice
        String optionChoice = scanner.nextLine().trim();

        // Execute logic for option 1: Detail Retrieval
        if (optionChoice.equals(String.valueOf(OPTION_ONE))) {
            // Prompt the user for their unique employee ID
            System.out.print("Enter your employee number: ");

            // Capture employee number input
            String employeeNumber = scanner.nextLine().trim();

            // --- DATA INTEGRITY VALIDATION ---
            // Ensure input contains only numerical digits
            if (!employeeNumber.matches("\\d+")) {
                // Print error message for character violation
                System.out.println("\nAccess Denied: Invalid characters identified. Please select one numerical symbol.");

                // Print termination sequence
                System.out.println("\nPROGRAM TERMINATED.");

                // Stop execution
                System.exit(0);
            }

            // Define storage for basic employee metadata
            String employeeName = "";
            String employeeBirthday = "";

            // Boolean flag to track if the ID exists in the database
            boolean isFound = false;

            // Attempt to read the database using NetBeans src path constant
            try (BufferedReader reader = new BufferedReader(new FileReader(DATABASE_CSV))) {
                // Discard the header row from the CSV file
                reader.readLine();

                String currentLine;

                // Iterate through the database file line by line
                while ((currentLine = reader.readLine()) != null) {
                    // Split values while respecting quoted strings containing commas
                    String[] employeeData = currentLine.split(",(?=(?:[^\"]*\"[^\"]*\")*[^\"]*$)");

                    // Match the ID in index 0 with the user input
                    if (employeeData[0].trim().equals(employeeNumber)) {
                        // Construct the full name: Last Name + First Name
                        employeeName = employeeData[2].replace("\"", "").trim() + " " + employeeData[1].replace("\"", "").trim();

                        // Capture the birthday field from index 3
                        employeeBirthday = employeeData[3].trim();

                        // Update flag and exit search loop
                        isFound = true;
                        break;
                    }
                }
            } catch (Exception exception) {
                // Fallback logic for local execution environments (root folder)
                try (BufferedReader readerRoot = new BufferedReader(new FileReader("Employee Database.csv"))) {
                    readerRoot.readLine();
                    String line;
                    while ((line = readerRoot.readLine()) != null) {
                        String[] data = line.split(",(?=(?:[^\"]*\"[^\"]*\")*[^\"]*$)");
                        if (data[0].trim().equals(employeeNumber)) {
                            employeeName = data[2].replace("\"", "").trim() + " " + data[1].replace("\"", "").trim();
                            employeeBirthday = data[3].trim();
                            isFound = true;
                            break;
                        }
                    }
                } catch (Exception e) {
                    System.out.println("\nError: Critical failure accessing the Employee Database.");
                }
            }

            // Handle scenario where employee ID does not exist in the record
            if (!isFound) {
                System.out.println("\nAccess Denied: Employee number unidentified. Please check the number again.");
                System.out.println("\nPROGRAM TERMINATED.");
                System.exit(0);
            }

            // Print formatted header for employee information
            System.out.println("\n— MOTORPH EMPLOYEE DETAILS —");
            System.out.println("1. Employee #: " + employeeNumber);
            System.out.println("2. Name: " + employeeName);
            System.out.println("3. Birthday: " + employeeBirthday);

            // Visual separator for professional layout
            System.out.println("\n—-------------------------------------------------------");

            // Friendly closure message
            System.out.println("\nThank you for using the MotorPH Payroll System!");
        } else if (optionChoice.equals(String.valueOf(OPTION_TWO))) {
            // Standard exit path for the employee portal
            System.out.println("\nThank you for using the MotorPH Payroll System!");
            System.exit(0);
        } else {
            // Catch-all error handling for invalid menu selections
            if (optionChoice.isEmpty() || !optionChoice.matches("\\d+")) {
                System.out.println("\nAccess Denied: Invalid characters identified. Please select one numerical symbol.");
            } else {
                System.out.println("\nAccess Denied: Invalid option identified. Please select one from the given options.");
            }

            // Terminate program after invalid input attempt
            System.out.println("\nPROGRAM TERMINATED.");
            System.exit(0);
        }
    }

    // Procedural method designed for the Payroll Staff Portal interface
    public static void processStaffPortal(Scanner scanner) {
        // Present administrative menu options
        System.out.println("[1] Process Payroll");

        // Option to terminate the current session
        System.out.println("[2] Exit the program");

        // Prompt for choice
        System.out.print("Select option: ");

        // Read choice and remove leading/trailing spaces
        String staffChoice = scanner.nextLine().trim();

        // Exit branch
        if (staffChoice.equals(String.valueOf(OPTION_TWO))) {
            System.out.println("\nThank you for using the MotorPH Payroll System!");
            System.exit(0);
        } else if (!staffChoice.equals(String.valueOf(OPTION_ONE))) {
            // Error handling for primary menu
            System.out.println("\nAccess Denied: Invalid option identified.");
            System.out.println("\nPROGRAM TERMINATED.");
            System.exit(0);
        }

        // Display secondary sub-menu for payroll scope
        System.out.println("\n[1] One employee");
        System.out.println("[2] All employees");
        System.out.println("[3] Exit the program");

        // Prompt for scope selection
        System.out.print("Select option: ");
        String subChoice = scanner.nextLine().trim();

        // Routing for individual employee payroll
        if (subChoice.equals(String.valueOf(OPTION_ONE))) {
            System.out.print("Enter the employee number: ");
            String targetEmployee = scanner.nextLine().trim();

            // Delegate to payroll engine with single employee flag
            processPayrollData(scanner, targetEmployee, true);
        } else if (subChoice.equals(String.valueOf(OPTION_TWO))) {
            // Delegate to payroll engine with batch processing flag
            processPayrollData(scanner, "ALL", false);
        } else if (subChoice.equals(String.valueOf(OPTION_THREE))) {
            System.out.println("\nThank you for using the MotorPH Payroll System!");
            System.exit(0);
        } else {
            // Error handling for sub-menu
            System.out.println("\nAccess Denied: Invalid option identified.");
            System.out.println("\nPROGRAM TERMINATED.");
            System.exit(0);
        }
    }

    // Core procedural method handling file parsing, time calculations, and salary math
    public static void processPayrollData(Scanner scanner, String targetEmployee, boolean isSingleEmployee) {
        // Initialize flag to verify target employee existence
        boolean targetFoundPremature = false;

        // Perform existence check if a specific employee ID was provided
        if (isSingleEmployee) {
            // Validate ID format
            if (!targetEmployee.matches("\\d+")) {
                System.out.println("\nAccess Denied: Invalid characters identified.");
                System.out.println("\nPROGRAM TERMINATED.");
                System.exit(0);
            }

            // Scan the database briefly to verify the ID
            try (BufferedReader reader = new BufferedReader(new FileReader(DATABASE_CSV))) {
                reader.readLine();
                String line;
                while ((line = reader.readLine()) != null) {
                    if (line.split(",")[0].trim().equals(targetEmployee)) {
                        targetFoundPremature = true;
                        break;
                    }
                }
            } catch (Exception e) {
                // Secondary check for root folder
                try (BufferedReader readerR = new BufferedReader(new FileReader("Employee Database.csv"))) {
                    readerR.readLine();
                    String line;
                    while ((line = readerR.readLine()) != null) {
                        if (line.split(",")[0].trim().equals(targetEmployee)) {
                            targetFoundPremature = true;
                            break;
                        }
                    }
                } catch (Exception ex) {
                }
            }

            // Deny access if ID is not found in the file
            if (!targetFoundPremature) {
                System.out.println("\nAccess Denied: Invalid employee number. Please try again.");
                System.out.println("\nPROGRAM TERMINATED.");
                System.exit(0);
            }
        }

        // Present month selection menu
        System.out.println("Select the month to process payroll:");
        System.out.println("1. June");
        System.out.println("2. July");
        System.out.println("3. August");
        System.out.println("4. September");
        System.out.println("5. October");
        System.out.println("6. November");
        System.out.println("7. December");

        // Special option for detailed history of a single employee
        if (isSingleEmployee) {
            System.out.println("8. Show All Months");
        }

        // Capture user's month selection
        System.out.print("Select option: ");
        String monthChoiceStr = scanner.nextLine().trim();
        int monthChoice = 0;

        try {
            // Attempt conversion to integer
            monthChoice = Integer.parseInt(monthChoiceStr);
        } catch (NumberFormatException exception) {
            // Handle non-integer entries
            System.out.println("\nAccess Denied: Invalid characters identified.");
            System.out.println("\nPROGRAM TERMINATED.");
            System.exit(0);
        }

        // Validate choice boundaries
        if (monthChoice < 1 || (isSingleEmployee && monthChoice > 8) || (!isSingleEmployee && monthChoice > 7)) {
            System.out.println("\nAccess Denied: Invalid option identified.");
            System.out.println("\nPROGRAM TERMINATED.");
            System.exit(0);
        }

        // Define storage arrays for bulk processing (No Collections Framework allowed)
        String[] employeeIdsToProcess = new String[50];
        String[] employeeNamesToProcess = new String[50];
        String[] employeeBirthdaysToProcess = new String[50];
        double[] employeeRatesToProcess = new double[50];

        // Counter for valid items in static arrays
        int employeeCount = 0;

        // Parse Employee Database to load processing queue
        try (BufferedReader reader = new BufferedReader(new FileReader(DATABASE_CSV))) {
            reader.readLine();
            String currentLine;
            while ((currentLine = reader.readLine()) != null) {
                // Skip empty lines
                if (currentLine.trim().isEmpty()) continue;

                // Advanced regex split to handle CSV commas within quotes
                String[] employeeData = currentLine.split(",(?=(?:[^\"]*\"[^\"]*\")*[^\"]*$)");
                String id = employeeData[0].trim();

                // Logic to filter for one specific ID or allow all
                if (!isSingleEmployee || id.equals(targetEmployee)) {
                    employeeIdsToProcess[employeeCount] = id;

                    // Assign name and birthday fields
                    employeeNamesToProcess[employeeCount] = employeeData[2].replace("\"", "").trim() + " " + employeeData[1].replace("\"", "").trim();
                    employeeBirthdaysToProcess[employeeCount] = employeeData[3].trim();

                    // Parse hourly rate and clean numeric string
                    String rateString = employeeData[employeeData.length - 1].replace("\"", "").replace(",", "").trim();
                    employeeRatesToProcess[employeeCount] = Double.parseDouble(rateString);

                    // Increment the counter for the loop
                    employeeCount++;
                }
            }
        } catch (Exception e) {
            // Failover database access for root directory
            try (BufferedReader rRoot = new BufferedReader(new FileReader("Employee Database.csv"))) {
                rRoot.readLine();
                String line;
                while ((line = rRoot.readLine()) != null) {
                    String[] data = line.split(",(?=(?:[^\"]*\"[^\"]*\")*[^\"]*$)");
                    if (!isSingleEmployee || data[0].trim().equals(targetEmployee)) {
                        employeeIdsToProcess[employeeCount] = data[0].trim();
                        employeeNamesToProcess[employeeCount] = data[2].replace("\"", "").trim() + " " + data[1].replace("\"", "").trim();
                        employeeBirthdaysToProcess[employeeCount] = data[3].trim();
                        String rs = data[data.length - 1].replace("\"", "").replace(",", "").trim();
                        employeeRatesToProcess[employeeCount] = Double.parseDouble(rs);
                        employeeCount++;
                    }
                }
            } catch (Exception ex) {
            }
        }

        // Define dynamic month ranges based on user selection
        int startMonthLoop = (monthChoice == 8) ? 6 : (monthChoice + 5);
        int endMonthLoop = (monthChoice == 8) ? 12 : (monthChoice + 5);

        // Iterate through all targeted employees
        for (int empIndex = 0; empIndex < employeeCount; empIndex++) {
            String currentEmpId = employeeIdsToProcess[empIndex];

            // Safely isolated header logic
            if (monthChoice >= 1 && monthChoice <= 7) {
                int m = monthChoice + 5;
                String headerMonthStr = "";
                String headerLastDay = "";
                String headerSuffix = "TH";
                switch (m) {
                    case 6:
                        headerMonthStr = "JUNE";
                        headerLastDay = "30";
                        headerSuffix = "TH";
                        break;
                    case 7:
                        headerMonthStr = "JULY";
                        headerLastDay = "31";
                        headerSuffix = "ST";
                        break;
                    case 8:
                        headerMonthStr = "AUGUST";
                        headerLastDay = "31";
                        headerSuffix = "ST";
                        break;
                    case 9:
                        headerMonthStr = "SEPTEMBER";
                        headerLastDay = "30";
                        headerSuffix = "TH";
                        break;
                    case 10:
                        headerMonthStr = "OCTOBER";
                        headerLastDay = "31";
                        headerSuffix = "ST";
                        break;
                    case 11:
                        headerMonthStr = "NOVEMBER";
                        headerLastDay = "30";
                        headerSuffix = "TH";
                        break;
                    case 12:
                        headerMonthStr = "DECEMBER";
                        headerLastDay = "31";
                        headerSuffix = "ST";
                        break;
                }
                // Output employee profile header
                System.out.println("\n— PAYROLL OF MOTORPH EMPLOYEE #" + currentEmpId + " FOR " + headerMonthStr + " 1ST TO " + headerLastDay + headerSuffix + " —\n");
            } else if (monthChoice == 8) {
                System.out.println("\n— PAYROLL OF MOTORPH EMPLOYEE #" + currentEmpId + " FOR JUNE TO DECEMBER —\n");
            }

            System.out.println("1. Employee #: " + currentEmpId);
            System.out.println("2. Name: " + employeeNamesToProcess[empIndex]);
            System.out.println("3. Birthday: " + employeeBirthdaysToProcess[empIndex] + "\n");

            // Sub-loop to process each required month for the current employee
            for (int actualMonth = startMonthLoop; actualMonth <= endMonthLoop; actualMonth++) {
                // Cumulative hours storage for both cutoffs
                double rawFirstCutoffHours = 0.0;
                double rawSecondCutoffHours = 0.0;

                // Open attendance file to calculate total hours worked in the specific month
                try (BufferedReader reader = new BufferedReader(new FileReader(ATTENDANCE_CSV))) {
                    reader.readLine();
                    String currentLine;
                    while ((currentLine = reader.readLine()) != null) {
                        String[] data = currentLine.split(",");

                        // Proceed only if the row matches the current employee ID
                        if (!data[0].trim().equals(currentEmpId)) continue;

                        // Split date format (MM/DD/YYYY)
                        String[] dateParts = data[3].trim().split("/");
                        int recordMonth = Integer.parseInt(dateParts[0]);
                        int recordDay = Integer.parseInt(dateParts[1]);

                        // Proceed if the record month matches the current loop month
                        if (recordMonth == actualMonth) {
                            // Convert time strings into decimal hour values
                            String[] loginTime = data[4].trim().split(":");
                            String[] logoutTime = data[5].trim().split(":");

                            double loginDouble = Double.parseDouble(loginTime[0]) + (Double.parseDouble(loginTime[1]) / 60.0);
                            double logoutDouble = Double.parseDouble(logoutTime[0]) + (Double.parseDouble(logoutTime[1]) / 60.0);

                            // Calculate daily hours within the 8AM-5PM window minus 1 hour lunch break
                            double dailyHours = (Math.min(logoutDouble, 17.0) - Math.max(loginDouble, 8.0)) - 1.0;

                            // Ensure negative hour logic results in zero
                            if (dailyHours < 0) dailyHours = 0;

                            // Assign daily hours to the first or second half of the month
                            if (recordDay <= 15) rawFirstCutoffHours += dailyHours;
                            else rawSecondCutoffHours += dailyHours;
                        }
                    }
                } catch (Exception e) {
                    // Failover attendance reading for root directory
                    try (BufferedReader readerB = new BufferedReader(new FileReader("Employee Attendance Record.csv"))) {
                        readerB.readLine();
                        String line;
                        while ((line = readerB.readLine()) != null) {
                            String[] d = line.split(",");
                            if (d[0].trim().equals(currentEmpId)) {
                                String[] dp = d[3].trim().split("/");
                                if (Integer.parseInt(dp[0]) == actualMonth) {
                                    String[] in = d[4].trim().split(":");
                                    String[] out = d[5].trim().split(":");
                                    double hrs = (Math.min(Double.parseDouble(out[0]) + Double.parseDouble(out[1]) / 60, 17.0) - Math.max(Double.parseDouble(in[0]) + Double.parseDouble(in[1]) / 60, 8.0)) - 1.0;
                                    if (Integer.parseInt(dp[1]) <= 15) rawFirstCutoffHours += Math.max(0, hrs);
                                    else rawSecondCutoffHours += Math.max(0, hrs);
                                }
                            }
                        }
                    } catch (Exception ex) {
                    }
                }

                // --- KEY CALCULATION FIX: ROUND HOURS BEFORE MULTIPLYING ---
                // Round hours to 2 decimal places to ensure calculation matches printed values
                double firstCutoffHours = Math.round(rawFirstCutoffHours * 100.0) / 100.0;
                double secondCutoffHours = Math.round(rawSecondCutoffHours * 100.0) / 100.0;

                // Calculate gross payouts for each cutoff using the rounded hour totals
                double firstGross = firstCutoffHours * employeeRatesToProcess[empIndex];
                double secondGross = secondCutoffHours * employeeRatesToProcess[empIndex];

                // Combined gross amount for government deduction bracket calculation
                double combinedGross = firstGross + secondGross;

                // Deduction variables initialization
                double sss = 0, ph = 0, pi = 0, tax = 0;

                // Perform deduction logic if the employee has earnings
                if (combinedGross > 0) {
                    // Statutory Fixed and Percentage Deductions
                    pi = 100.0;
                    ph = (combinedGross * 0.03) / 2;
                    sss = combinedGross * 0.045;

                    // Taxable income calculation
                    double taxable = combinedGross - (sss + ph + pi);

                    // Withholding tax brackets (Procedural Logic)
                    if (taxable > 20832 && taxable <= 33333) {
                        tax = (taxable - 20833) * 0.20;
                    } else if (taxable > 33333 && taxable <= 66667) {
                        tax = 2500 + ((taxable - 33333) * 0.25);
                    } else if (taxable > 66667) {
                        tax = 10833 + ((taxable - 66667) * 0.30);
                    }
                }

                // Compute Net Salary for both periods
                double totalDeductions = sss + ph + pi + tax;
                double netCutoff2 = secondGross - totalDeductions;

                // Month name selection based on loop index
                String monthNameStr = "";
                switch (actualMonth) {
                    case 6:
                        monthNameStr = "June";
                        break;
                    case 7:
                        monthNameStr = "July";
                        break;
                    case 8:
                        monthNameStr = "August";
                        break;
                    case 9:
                        monthNameStr = "September";
                        break;
                    case 10:
                        monthNameStr = "October";
                        break;
                    case 11:
                        monthNameStr = "November";
                        break;
                    case 12:
                        monthNameStr = "December";
                        break;
                }

                String lastDay = (actualMonth == 6 || actualMonth == 9 || actualMonth == 11) ? "30" : "31";

                // --- HEADER FOR FIRST CUTOFF ---
                System.out.println("--- FIRST CUTOFF ---");

                // --- Final Screen Display for First Cutoff ---
                System.out.println("1. Cutoff Date: " + monthNameStr + " 1 to 15");
                System.out.printf("2. Total Hours Worked: %.2f\n", firstCutoffHours);
                System.out.printf("3. Gross Salary: PHP %.4f\n", firstGross);
                System.out.printf("4. Net Salary: PHP %.4f\n\n", firstGross);

                // --- HEADER FOR SECOND CUTOFF ---
                System.out.println("--- SECOND CUTOFF ---");

                // --- Final Screen Display for Second Cutoff (Deduction Payout) ---
                System.out.println("1. Cutoff Date: " + monthNameStr + " 16 to " + lastDay);
                System.out.printf("2. Total Hours Worked: %.2f\n", secondCutoffHours);
                System.out.printf("3. Gross Salary: PHP %.4f\n", secondGross);
                System.out.println("4. Each Deduction:");

                // Print specific deduction items
                System.out.printf("- SSS: PHP %.4f\n- PhilHealth: PHP %.4f\n- Pag-IBIG: PHP %.4f\n- Withholding Tax: PHP %.4f\n", sss, ph, pi, tax);

                // Print total deductions and net pay
                System.out.printf("5. Total Deductions: PHP %.4f\n", totalDeductions);
                System.out.printf("6. Net Salary: PHP %.4f\n\n", netCutoff2);
            }
        } // Correctly closing the empIndex loop here!

        // Final visual border
        System.out.println("—-------------------------------------------------------");

        // Process complete message
        System.out.println("\nPayroll Processed Successfully.\n\nThank you for using the MotorPH Payroll System!");

        // Exit system securely
        System.exit(0);
    }
