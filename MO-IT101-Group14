    // Procedural method for the Employee Portal
    public static void processEmployeePortal(Scanner scanner) {
        // Display options for the employee
        System.out.println("[1] Enter your employee number");
        // Display exit option
        System.out.println("[2] Exit the program");
        // Ask for option
        System.out.print("Select option: ");
        // Read the chosen option
        String optionChoice = scanner.nextLine().trim();

        // Check if option 1 was selected
        if (optionChoice.equals(String.valueOf(OPTION_ONE))) {
            // Ask for employee number
            System.out.print("Enter your employee number: ");
            // Read the employee number
            String employeeNumber = scanner.nextLine().trim();

            // --- VALIDATION FOR INVALID CHARACTERS ---
            if (!employeeNumber.matches("\\d+")) {
                // Print constraint for non-numerical characters
                System.out.println("\nAccess Denied: Invalid characters identified. Please select one numerical symbol from the options above.");
                // Print termination string
                System.out.println("\nPROGRAM TERMINATED.");
                // Terminate
                System.exit(0);
            }

            // Initialize variable to hold employee name
            String employeeName = "";
            // Initialize variable to hold employee birthday
            String employeeBirthday = "";
            // Flag to check if employee exists
            boolean isFound = false;

            // Try block to read the CSV file
            try (BufferedReader reader = new BufferedReader(new FileReader("Employee Database.csv"))) {
                // Skip the header line of the CSV
                reader.readLine();
                // Variable to hold each line
                String currentLine;

                // Loop through all lines in the file
                while ((currentLine = reader.readLine()) != null) {
                    // Split the comma-separated values properly ignoring commas in quotes
                    String[] employeeData = currentLine.split(",(?=(?:[^\"]*\"[^\"]*\")*[^\"]*$)");
                    // Check if the current line matches the inputted employee number
                    if (employeeData[0].trim().equals(employeeNumber)) {
                        // Assign the full name by concatenating last and first name
                        employeeName = employeeData[2].replace("\"", "").trim() + " " + employeeData[1].replace("\"", "").trim();
                        // Assign the birthday value
                        employeeBirthday = employeeData[3].trim();
                        // Mark as found
                        isFound = true;
                        // Break out of the loop since employee is found
                        break;
                    }
                }
                // Catch any file reading errors
            } catch (Exception exception) {
                // Print standard error message
                System.out.println("\nError reading Employee Database.csv");
            }

            // If employee was not found in the loop
            if (!isFound) {
                // Print strict unidentified ID message
                System.out.println("\nAccess Denied: Employee number unidentified. Please check the number again.");
                // Print termination string
                System.out.println("\nPROGRAM TERMINATED.");
                // Exit system
                System.exit(0);
            }

            // Display employee details header with spacing
            System.out.println("\n— MOTORPH EMPLOYEE DETAILS —");
            // Display the employee number
            System.out.println("1. Employee #: " + employeeNumber);
            // Display the employee name
            System.out.println("2. Name: " + employeeName);
            // Display the employee birthday
            System.out.println("3. Birthday: " + employeeBirthday);
            // Print visual separator
            System.out.println("\n—-------------------------------------------------------");
            // Display standard farewell message
            System.out.println("\nThank you for using the MotorPH Payroll System!");

            // Check if option 2 was selected
        } else if (optionChoice.equals(String.valueOf(OPTION_TWO))) {
            // Display standard farewell message
            System.out.println("\nThank you for using the MotorPH Payroll System!");
            // Terminate program
            System.exit(0);
            // If an invalid option was entered
        } else {
            // Identify if input is blank or non-numeric
            if (optionChoice.isEmpty() || !optionChoice.matches("\\d+")) {
                // Print string constraint for non-numerical
                System.out.println("\nAccess Denied: Invalid characters identified. Please select one numerical symbol from the options above.");
                // If numerical but invalid
            } else {
                // Print string constraint for wrong numerical
                System.out.println("\nAccess Denied: Invalid option identified. Please select one numerical symbol from the options.");
            }
            // Print termination string
            System.out.println("\nPROGRAM TERMINATED.");
            // Terminate program
            System.exit(0);
        }
    }

