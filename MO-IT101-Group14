    // Core procedural method handling file parsing and calculation
    public static void processPayrollData(Scanner scanner, String targetEmployee, boolean isSingleEmployee) {

        // --- PRE-VALIDATION CHECK FOR SINGLE EMPLOYEE ---
        boolean targetFoundPremature = false;
        if (isSingleEmployee) {
            // Validate characters first for Payroll Staff side too
            if (!targetEmployee.matches("\\d+")) {
                System.out.println("\nAccess Denied: Invalid characters identified. Please select one numerical symbol from the options above.");
                System.out.println("\nPROGRAM TERMINATED.");
                System.exit(0);
            }

            try (BufferedReader reader = new BufferedReader(new FileReader("Employee Database.csv"))) {
                reader.readLine();
                String line;
                while ((line = reader.readLine()) != null) {
                    if (line.split(",")[0].trim().equals(targetEmployee)) {
                        targetFoundPremature = true;
                        break;
                    }
                }
            } catch (Exception e) {}

            if (!targetFoundPremature) {
                System.out.println("\nAccess Denied: Invalid employee number. Please try again.");
                System.out.println("\nPROGRAM TERMINATED.");
                System.exit(0);
            }
        }

        // Display month selection menu
        System.out.println("Select the month to process payroll:");
        // June option
        System.out.println("1. June");
        // July option
        System.out.println("2. July");
        // August option
        System.out.println("3. August");
        // September option
        System.out.println("4. September");
        // October option
        System.out.println("5. October");
        // November option
        System.out.println("6. November");
        // December option
        System.out.println("7. December");

        // If single employee, offer Show All option
        if (isSingleEmployee) {
            // Display Show All
            System.out.println("8. Show All Months");
        }

        // Prompt for month choice
        System.out.print("Select option: ");
        // Read choice
        String monthChoiceStr = scanner.nextLine().trim();
        // Variable to hold integer parsed choice
        int monthChoice = 0;

        // Try to parse the choice to integer
        try {
            // Parse string to int
            monthChoice = Integer.parseInt(monthChoiceStr);
            // Catch parsing failure
        } catch (NumberFormatException exception) {
            // Print strict constraint for non-numerical
            System.out.println("\nAccess Denied: Invalid characters identified. Please select one numerical symbol from the options above.");
            // Print termination
            System.out.println("\nPROGRAM TERMINATED.");
            // Exit safely
            System.exit(0);
        }

        // Check if the input is within valid boundary
        if (monthChoice < 1 || (isSingleEmployee && monthChoice > 8) || (!isSingleEmployee && monthChoice > 7)) {
            // Invalid selection handling
            System.out.println("\nAccess Denied: Invalid option identified. Please select one numerical symbol from the options.");
            // Display termination
            System.out.println("\nPROGRAM TERMINATED.");
            // Exit
            System.exit(0);
        }

        // We will collect all employee IDs to process into a primitive array (NO COLLECTIONS/LISTS)
        String[] employeeIdsToProcess = new String[50];
        // Array to store names
        String[] employeeNamesToProcess = new String[50];
        // Array to store birthdays
        String[] employeeBirthdaysToProcess = new String[50];
        // Array to store hourly rates
        double[] employeeRatesToProcess = new double[50];
        // Counter for how many employees are valid
        int employeeCount = 0;

        // Read Employee Database directly
        try (BufferedReader reader = new BufferedReader(new FileReader("Employee Database.csv"))) {
            // Skip header
            reader.readLine();
            // Variable for current line
            String currentLine;

            // Read line by line
            while ((currentLine = reader.readLine()) != null) {
                // Ignore empty lines
                if (currentLine.trim().isEmpty()) continue;
                // Split standard comma separated values
                String[] employeeData = currentLine.split(",(?=(?:[^\"]*\"[^\"]*\")*[^\"]*$)");
                // Extract employee ID
                String id = employeeData[0].trim();

                // Check if we are adding all or just the specific one
                if (!isSingleEmployee || id.equals(targetEmployee)) {
                    // Add ID to array
                    employeeIdsToProcess[employeeCount] = id;
                    // Add combined name to array
                    employeeNamesToProcess[employeeCount] = employeeData[2].replace("\"", "").trim() + " " + employeeData[1].replace("\"", "").trim();
                    // Add birthday
                    employeeBirthdaysToProcess[employeeCount] = employeeData[3].trim();
                    // Clean comma from hourly rate string
                    String rateString = employeeData[employeeData.length - 1].replace("\"", "").replace(",", "").trim();
                    // Parse double value for rate
                    employeeRatesToProcess[employeeCount] = Double.parseDouble(rateString);
                    // Increment counter
                    employeeCount++;
                }
            }
            // Catch exceptions during DB read
        } catch (Exception e) {
            // Print error fallback
            System.out.println("\nError reading Employee Database.");
        }

        // Determine start and end constraints for the month loop based on input
        int startMonthLoop = (monthChoice == 8) ? 6 : (monthChoice + 5);
        // Determine the end constraints
        int endMonthLoop = (monthChoice == 8) ? 12 : (monthChoice + 5);

        // Process sequentially for every targeted employee in our static array size
        for (int empIndex = 0; empIndex < employeeCount; empIndex++) {
            // Extract the current ID context
            String currentEmpId = employeeIdsToProcess[empIndex];
            // Print employee details header
            System.out.println("\n— MOTORPH EMPLOYEE DETAILS —");
            // Print the ID
            System.out.println("1. Employee #: " + currentEmpId);
            // Print the Name
            System.out.println("2. Name: " + employeeNamesToProcess[empIndex]);
            // Print the Birthday
            System.out.println("3. Birthday: " + employeeBirthdaysToProcess[empIndex]);
            // Print spacing header for payroll details
            System.out.println("\n— MOTORPH PAYROLL DETAILS —");

            // Loop through selected month/months
            for (int actualMonth = startMonthLoop; actualMonth <= endMonthLoop; actualMonth++) {
                // Variable to hold hours for first cutoff
                double firstCutoffHours = 0.0;
                // Variable to hold hours for second cutoff
                double secondCutoffHours = 0.0;

                // Read attendance dynamically inside the loop
                try (BufferedReader reader = new BufferedReader(new FileReader("Employee Attendance Record.csv"))) {
                    // Skip header
                    reader.readLine();
                    // Holds active string line
                    String currentLine;

                    // Loop while rows exist
                    while ((currentLine = reader.readLine()) != null) {
                        // Ignore empty rows
                        if (currentLine.trim().isEmpty()) continue;
                        // Split row into components
                        String[] attendanceData = currentLine.split(",");

                        // Check if row pertains to our current employee
                        if (!attendanceData[0].trim().equals(currentEmpId)) continue;

                        // Parse the date (Format: MM/DD/YYYY)
                        String[] dateParts = attendanceData[3].trim().split("/");
                        // Extract month integer
                        int recordMonth = Integer.parseInt(dateParts[0]);
                        // Extract day integer
                        int recordDay = Integer.parseInt(dateParts[1]);

                        // Proceed only if the record falls in the current active target month
                        if (recordMonth == actualMonth) {
                            // Extract login hour segment
                            String[] loginTime = attendanceData[4].trim().split(":");
                            // Extract logout hour segment
                            String[] logoutTime = attendanceData[5].trim().split(":");

                            // Convert login to fractional double value
                            double loginDouble = Double.parseDouble(loginTime[0]) + (Double.parseDouble(loginTime[1]) / 60.0);
                            // Convert logout to fractional double value
                            double logoutDouble = Double.parseDouble(logoutTime[0]) + (Double.parseDouble(logoutTime[1]) / 60.0);

                            // Apply strict constraint: Minimum time recognized is 8:00 AM
                            double effectiveLogin = Math.max(loginDouble, 8.0);
                            // Apply strict constraint: Maximum time recognized is 5:00 PM (17:00)
                            double effectiveLogout = Math.min(logoutDouble, 17.0);

                            // Compute hours ignoring extra hours and subtracting 1 hour break
                            double dailyHours = (effectiveLogout - effectiveLogin) - 1.0;
                            // Ensure negative numbers fallback to 0
                            if (dailyHours < 0) dailyHours = 0;

                            // Distribute calculated daily hours to exact cutoff period
                            if (recordDay >= 1 && recordDay <= 15) {
                                // Increment first cutoff
                                firstCutoffHours += dailyHours;
                                // Anything past 15 goes to second cutoff
                            } else {
                                // Increment second cutoff
                                secondCutoffHours += dailyHours;
                            }
                        }
                    }
                } catch (Exception e) {}

                // Calculate Gross Salary for Cutoff 1 maintaining precise decimals
                double firstGross = firstCutoffHours * employeeRatesToProcess[empIndex];
                // Calculate Gross Salary for Cutoff 2 maintaining precise decimals
                double secondGross = secondCutoffHours * employeeRatesToProcess[empIndex];

                // Combined monthly gross for government deductions
                double combinedMonthlyGross = firstGross + secondGross;

                // Declare deduction variables locally
                double sssDeduction = 0.0;
                double philhealthDeduction = 0.0;
                double pagibigDeduction = 0.0;
                double taxDeduction = 0.0;

                // Only compute taxes and deductions if there is actual combined income
                if (combinedMonthlyGross > 0) {
                    // Placeholder logic for deductions based on typical MotorPH rules
                    pagibigDeduction = 100.0;
                    philhealthDeduction = (combinedMonthlyGross * 0.03) / 2;
                    sssDeduction = combinedMonthlyGross * 0.045;

                    // Deduct contributions to get Taxable Income
                    double taxableIncome = combinedMonthlyGross - (sssDeduction + philhealthDeduction + pagibigDeduction);

                    // Apply strict procedural nested branching for withholding tax
                    if (taxableIncome > 20832 && taxableIncome <= 33333) {
                        taxDeduction = (taxableIncome - 20833) * 0.20;
                    } else if (taxableIncome > 33333 && taxableIncome <= 66667) {
                        taxDeduction = 2500 + ((taxableIncome - 33333) * 0.25);
                    } else if (taxableIncome > 66667) {
                        taxDeduction = 10833 + ((taxableIncome - 66667) * 0.30);
                    }
                }

                // Net Salaries
                double netSalaryCutoff1 = firstGross;
                double totalDeductions = sssDeduction + philhealthDeduction + pagibigDeduction + taxDeduction;
                double netSalaryCutoff2 = secondGross - totalDeductions;

                // Month string mapping
                String monthNameStr = "";
                switch (actualMonth) {
                    case 6: monthNameStr = "June"; break;
                    case 7: monthNameStr = "July"; break;
                    case 8: monthNameStr = "August"; break;
                    case 9: monthNameStr = "September"; break;
                    case 10: monthNameStr = "October"; break;
                    case 11: monthNameStr = "November"; break;
                    case 12: monthNameStr = "December"; break;
                }

                // --- Print First Cutoff ---
                System.out.println("1. Cutoff Date: " + monthNameStr + " 1 to " + monthNameStr + " 15");
                System.out.printf("2. Total Hours Worked: %.3f\n", firstCutoffHours);
                System.out.printf("3. Gross Salary: %.3f\n", firstGross);
                System.out.printf("4. Net Salary: %.3f\n\n", netSalaryCutoff1);

                // --- Print Second Cutoff ---
                System.out.println("1. Cutoff Date: " + monthNameStr + " 16 to " + monthNameStr + " 30/31 (Second payout includes all deductions)");
                System.out.printf("2. Total Hours Worked: %.3f\n", secondCutoffHours);
                System.out.printf("3. Gross Salary: %.3f\n", secondGross);
                System.out.println("4. Each Deduction:");
                System.out.printf("- SSS: %.3f\n", sssDeduction);
                System.out.printf("- PhilHealth: %.3f\n", philhealthDeduction);
                System.out.printf("- Pag-IBIG: %.3f\n", pagibigDeduction);
                System.out.printf("- Withholding Tax: %.3f\n", taxDeduction);
                System.out.printf("5. Total Deductions: %.3f\n", totalDeductions);
                System.out.printf("6. Net Salary: %.3f\n\n", netSalaryCutoff2);
            }
        }

        // Final footer spacing
        System.out.println("—-------------------------------------------------------");
        System.out.println("\nPayroll Processed Successfully.\n\nThank you for using the MotorPH Payroll System!");
        System.exit(0);
    }
